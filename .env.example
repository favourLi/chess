# 复制为 .env 后按需填写（勿提交 .env）
# Linux/macOS: export $(grep -v '^#' .env | xargs) 再启动 node
# Windows PowerShell: 见 DEPLOY.md

PORT=3030

# 生产环境必填：随机长字符串，Access / Refresh 须不同
# openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# 可选：限制浏览器来源（多个用英文逗号分隔）。不设置则与开发相同，反射请求 Origin（宽松）
# CORS_ORIGIN=https://chess.example.com

# 可选：本地验收「生产包 + 同一 Node 端口」时设为 1（需先 npm run build）
# SERVE_DIST=1
